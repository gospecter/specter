{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/PostFrontmatterAny",
  "definitions": {
    "PostFrontmatterAny": {
      "anyOf": [
        {
          "$ref": "#/definitions/PostFrontmatterV1"
        },
        {
          "$ref": "#/definitions/PostFrontmatterV2"
        }
      ],
      "description": "Union of both shapes — what the parser must accept during the deprecation window. Either `cms` block OR `ghost_*` keys must be present for a file to be considered tracked; bare files have neither and are pending push."
    },
    "PostFrontmatterV1": {
      "$ref": "#/definitions/PostFrontmatter",
      "description": "Legacy v1 frontmatter — flat `ghost_*` keys. Currently the only shape on disk."
    },
    "PostFrontmatter": {
      "type": "object",
      "properties": {
        "ghost_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "ghost_slug": {
          "type": [
            "string",
            "null"
          ]
        },
        "ghost_status": {
          "type": "string",
          "enum": [
            "draft",
            "published",
            "scheduled"
          ]
        },
        "ghost_updated_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "local_updated_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "feature_image": {
          "type": [
            "string",
            "null"
          ]
        },
        "excerpt": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "ghost_id",
        "ghost_slug",
        "ghost_status",
        "ghost_updated_at",
        "local_updated_at",
        "tags",
        "feature_image",
        "excerpt"
      ],
      "additionalProperties": false
    },
    "PostFrontmatterV2": {
      "type": "object",
      "properties": {
        "cms": {
          "type": "object",
          "properties": {
            "platform": {
              "type": "string",
              "enum": [
                "ghost",
                "shopify"
              ]
            },
            "id": {
              "type": "string",
              "description": "Native ID from the CMS — opaque to the daemon."
            },
            "slug": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "published",
                "scheduled"
              ]
            },
            "updated_at": {
              "type": "string"
            }
          },
          "required": [
            "platform",
            "id",
            "slug",
            "status",
            "updated_at"
          ],
          "additionalProperties": false
        },
        "local_updated_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "feature_image": {
          "type": [
            "string",
            "null"
          ]
        },
        "excerpt": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "cms",
        "local_updated_at",
        "tags",
        "feature_image",
        "excerpt"
      ],
      "additionalProperties": false,
      "description": "V2 frontmatter — namespaced `cms` block. Written by v0.4.0+; readable by v0.3.2+. Top-level user fields (`tags`, `feature_image`, `excerpt`, `local_updated_at`) keep their current location."
    }
  }
}
