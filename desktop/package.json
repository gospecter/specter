{
  "name": "specter-desktop",
  "version": "0.6.2",
  "description": "Specter tray app for Windows and Linux",
  "main": "build/main/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json && node scripts/copy-renderer.cjs",
    "dev": "concurrently \"tsc -p tsconfig.json --watch\" \"tsc -p tsconfig.renderer.json --watch\" \"node scripts/copy-renderer.cjs && electron .\"",
    "start": "electron .",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "concurrently": "^8.2.2",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "aabergkvist AB",
  "license": "AGPL-3.0-only"
}
